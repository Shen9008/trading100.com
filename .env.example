# Site
NEXT_PUBLIC_SITE_URL=https://trading100.com

# Finnhub (primary daily news + quotes) — https://finnhub.io/
# Set on Worker: wrangler secret put FINNHUB_API_KEY
FINNHUB_API_KEY=

# Protects POST /api/cron/* (set same value in GitHub Actions secrets)
CRON_SECRET=

# NewsAPI (optional fallback — blocked on Cloudflare IPs) — https://newsapi.org/
NEWSAPI_API_KEY=

# Marketaux (optional fallback news) — https://www.marketaux.com/
MARKETAUX_API_KEY=

# FRED (optional economic data) — https://fred.stlouisfed.org/docs/api/fred/
FRED_API_KEY=
